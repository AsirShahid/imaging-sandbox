{
  "Name": "Imaging Sandbox (public, read-only)",

  // Orthanc is never reachable directly from the internet: the public path is
  // the read-only-guarded /dicom-web/ location in proxy/default.conf, and the
  // admin port is published on 127.0.0.1 only (SSH tunnel). So HTTP auth is off
  // and access control lives at the edge. Do NOT publish 8042 on 0.0.0.0.
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": false,

  // Ingest is DICOMweb STOW from the admin tunnel only — no classic DIMSE port.
  "DicomServerEnabled": false,

  "PostgreSQL": {
    "EnableIndex": true,
    "EnableStorage": false,
    "Host": "postgres",
    "Port": 5432,
    "Database": "orthanc",
    "Username": "orthanc"
    // Password is injected via ORTHANC__POSTGRESQL__PASSWORD (see .env)
  },

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/",
    "EnableWado": true,
    "WadoRoot": "/wado"
  },

  "StableAge": 60,
  "StorageCompression": true,
  "OverwriteInstances": true,

  // Private-data guard. Studies labelled `private` (e.g. ADNI, loaded via
  // scripts/load_adni.sh) are never listed or served on the public DICOMweb
  // edge, even though they live in this same Orthanc. Admin-tunnel access
  // (127.0.0.1:8042) is unaffected. See orthanc/private_guard.py. Defining
  // PythonScript also enables the bundled Python plugin.
  "PythonScript": "/scripts/private_guard.py"
}
