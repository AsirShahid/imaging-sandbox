# Copy to .env and fill in. .env is gitignored.

# Public domain — configured in Nginx Proxy Manager (which terminates TLS).
# Informational here; the stack itself is same-origin and domain-agnostic.
DOMAIN=imaging.example.com

# Strong, unique. Used by both Postgres and Orthanc.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Only needed if you wire NPM via a shared docker network (see docs/DEPLOY.md,
# "Option A"). Set to the network your NPM container is attached to.
# NPM_NETWORK=npm_default
